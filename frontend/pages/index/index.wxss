/* 页面容器 - 移除 padding，让内容占满 */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  padding: 0;  /* 移除 padding，交给子元素控制 */
}

/* 搜索栏 - 占满宽度，减少顶部间距 */
.search-bar {
  margin: 0;  /* 移除 margin */
  padding: 20rpx 30rpx;  /* 左右留白，上下紧凑 */
  background: #fff;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.search-bar .icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-bar input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 60rpx;
  line-height: 60rpx;
}

.placeholder {
  color: #bbb;
  font-size: 30rpx;
}

/* 快捷标签 - 左右贴边 */
.quick-tags {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;  /* 减少 padding */
  background: #fff;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.tag-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tag-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.tag-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 标签切换 - 占满宽度 */
.tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  width: 100%;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f5f5f5;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
  font-weight: 500;
  margin: 0 10rpx;  /* 标签间间距 */
}

.tab:first-child {
  margin-left: 0;
}

.tab:last-child {
  margin-right: 0;
}

.tab.active {
  background: #ff6b6b;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3);
}

/* 列表区域 - 左右贴边 */
.list-wrapper {
  padding: 20rpx;  /* 控制卡片与屏幕边缘的间距 */
  width: 100%;
  box-sizing: border-box;
}

/* 加载组件 - 占满宽度 */
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
  width: 100%;
}