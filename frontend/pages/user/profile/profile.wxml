<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-section" bindtap="editProfile">
      <view class="avatar">
        <image 
          wx:if="{{avatarUrl}}" 
          src="{{avatarUrl}}" 
          mode="aspectFill"
          lazy-load
          binderror="onAvatarError"
        />
        <text wx:else class="avatar-placeholder">👤</text>
      </view>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
        <text class="username" wx:if="{{userInfo.username}}">@{{userInfo.username}}</text>
        <text class="login-tip" wx:if="{{!isLogin}}" bindtap="goLogin">点击登录账号</text>
      </view>
      <text class="arrow" wx:if="{{isLogin}}">›</text>
    </view>

    <!-- 数据统计 -->
    <view class="stats-bar" wx:if="{{isLogin}}">
      <view class="stat-item" bindtap="goFavorites">
        <text class="num">{{stats.favorites}}</text>
        <text class="label">收藏</text>
      </view>
      <view class="stat-item" bindtap="goMyRecipes">
        <text class="num">{{stats.recipes}}</text>
        <text class="label">菜谱</text>
      </view>
      <!-- <view class="stat-item" bindtap="goHistory">
        <text class="num">{{stats.history}}</text>
        <text class="label">浏览</text>
      </view> -->
    </view>
  </view>

  <!-- 功能列表（已登录显示） -->
  <view class="menu-list" wx:if="{{isLogin}}">
    <view class="menu-group">
      <view class="menu-item" bindtap="goFavorites">
        <text class="icon">⭐</text>
        <text class="title">我的收藏</text>
        <text class="arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="goMyRecipes">
        <text class="icon">📝</text>
        <text class="title">我的菜谱</text>
        <text class="arrow">›</text>
      </view>

      <!-- <view class="menu-item" bindtap="goHistory">
        <text class="icon">📖</text>
        <text class="title">浏览历史</text>
        <text class="arrow">›</text>
      </view> -->
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goSettings">
        <text class="icon">⚙️</text>
        <text class="title">设置</text>
        <text class="arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goAbout">
        <text class="icon">ℹ️</text>
        <text class="title">关于 DishMind</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item logout" bindtap="logout">
        <text class="icon">🚪</text>
        <text class="title">退出登录</text>
      </view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view class="not-login" wx:if="{{!isLogin}}">
    <text class="empty-icon">🔒</text>
    <text class="empty-text">登录后查看个人中心</text>
    <button class="login-btn" bindtap="goLogin">立即登录</button>
  </view>
</view>