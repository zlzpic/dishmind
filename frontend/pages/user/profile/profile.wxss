/* 页面容器 - 移除 padding */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  padding: 0;
}

/* 用户信息卡片 - 左右贴边，顶部无 margin */
.user-card {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  margin: 0;  /* 移除 margin */
  border-radius: 0 0 24rpx 24rpx;  /* 底部圆角，顶部直角 */
  padding: 60rpx 30rpx 40rpx;  /* 调整 padding */
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(255,107,107,0.3);
  width: 100%;
  box-sizing: border-box;
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  overflow: hidden;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.username {
  font-size: 26rpx;
  opacity: 0.9;
}

.login-tip {
  font-size: 28rpx;
  opacity: 0.9;
  text-decoration: underline;
}

.arrow {
  font-size: 40rpx;
  opacity: 0.8;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  border-top: 2rpx solid rgba(255,255,255,0.2);
  padding-top: 30rpx;
}

.stat-item {
  text-align: center;
  padding: 0 20rpx;
}

.num {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.label {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 菜单列表 - 左右贴边 */
.menu-list {
  margin-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.menu-group {
  background: #fff;
  margin: 0 0 20rpx 0;  /* 左右 margin 为 0 */
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  width: 100%;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;  /* 统一左右 padding */
  border-bottom: 2rpx solid #f5f5f5;
  width: 100%;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 50rpx;
  text-align: center;
  flex-shrink: 0;
}

.menu-item .title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.menu-item .arrow {
  color: #ccc;
  font-size: 32rpx;
}

.menu-item.logout .title {
  color: #ff4d4f;
}

/* 未登录状态 - 左右贴边 */
.not-login {
  text-align: center;
  padding: 120rpx 30rpx;
  background: #fff;
  margin: 20rpx 0 0 0;  /* 左右 margin 为 0 */
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 30rpx;
  display: block;
  margin-bottom: 40rpx;
}

.login-btn {
  background: #ff6b6b;
  color: #fff;
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(255,107,107,0.3);
  margin: 0 auto;
  display: block;
}