.container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 文件夹标签 */
.folder-tabs {
  background: #fff;
  padding: 20rpx;
  white-space: nowrap;
  border-bottom: 2rpx solid #eee;
  display: flex;
  align-items: center;
}

.folder-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 30rpx;
  margin-right: 20rpx;
  position: relative;
}

.folder-tab.active {
  background: #ff6b6b;
  color: #fff;
  font-weight: bold;
}

.folder-tab.add {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-size: 36rpx;
}

/* 菜谱列表 */
.recipe-list {
  padding: 20rpx;
}

.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.image-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.placeholder-text {
  font-size: 48rpx;
  color: rgba(255,255,255,0.9);
  font-weight: bold;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.meta {
  font-size: 26rpx;
  color: #999;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.actions text {
  font-size: 24rpx;
  color: #ff6b6b;
  padding: 8rpx 16rpx;
  background: rgba(255,107,107,0.1);
  border-radius: 8rpx;
  text-align: center;
}

.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
  font-size: 30rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-content input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btns button {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border: none;
}

.modal-btns button.primary {
  background: #ff6b6b;
  color: #fff;
}
/* 在原有样式基础上增加 */

/* 移动到弹窗中的文件夹列表 */
.folder-list {
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 30rpx;
}

.folder-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: all 0.3s;
}

.folder-option:active {
  background: #f9f9f9;
}

.folder-option.active {
  background: #fff5f5;
  color: #ff6b6b;
}

.folder-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.folder-name {
  flex: 1;
  font-size: 30rpx;
}

.check {
  font-size: 32rpx;
  font-weight: bold;
}

/* 按钮禁用状态 */
button[disabled] {
  opacity: 0.5;
}
/* pages/user/favorites/favorites.wxss */

/* 操作按钮容器 */
.item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
  background: #fff;
  margin-top: -10rpx;  /* 与卡片内容紧贴 */
  border-bottom-left-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 基础按钮样式 */
.item-actions text {
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  transition: all 0.3s;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
}

/* 移动按钮 - 蓝色系 */
.item-actions text:first-child {
  background: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #bae7ff;
}

.item-actions text:first-child:active {
  background: #bae7ff;
  transform: scale(0.95);
}

/* 删除按钮 - 红色系 */
.item-actions text:last-child {
  background: #fff1f0;
  color: #ff4d4f;
  border: 2rpx solid #ffa39e;
}

.item-actions text:last-child:active {
  background: #ffccc7;
  transform: scale(0.95);
}

/* 如果没有其他样式，请确保卡片布局正确 */
.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.recipe-card .image-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.placeholder-text {
  font-size: 48rpx;
  color: rgba(255,255,255,0.9);
  font-weight: bold;
}

.recipe-card .info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 20rpx 0;
}

.recipe-card .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-card .meta {
  font-size: 24rpx;
  color: #999;
}