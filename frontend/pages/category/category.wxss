.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
  padding: 0;
}

/* 已选标签栏 */
.selected-bar {
  background: #fff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.selected-tags {
  flex: 1;
  white-space: nowrap;
}

.selected-tags tag-pill {
  margin-right: 16rpx;
  display: inline-block;
}

.clear-btn {
  color: #999;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  flex-shrink: 0;
}

/* 分类列表 */
.category-list {
  padding: 20rpx;
}

.category-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.cat-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #ff6b6b;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-grid .tag {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.tag-grid .tag.active {
  background: #ff6b6b;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 1000;
}

.filter-btn {
  background: #ff6b6b;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.4);
}

/* 结果区域 */
.result-area {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.change-filter {
  color: #ff6b6b;
  font-size: 28rpx;
}
