/* 页面容器 - 紧贴顶部，左右占满 */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  width: 100%;
  padding: 0;
  padding-bottom: 40rpx;
}

/* 封面区域 - 紧贴顶部，无圆角，左右占满 */
.cover-section {
  height: 500rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 40rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  border-radius: 0;  /* 顶部无圆角 */
}

.cover-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  z-index: 1;
}

.cover-content {
  position: relative;
  z-index: 2;
  width: 100%;
}

.cover-section .title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  display: block;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
}

.meta-bar {
  display: flex;
  gap: 60rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-item .label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}

.meta-item .value {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 操作栏 - 左右贴边，无外边距 */
.action-bar {
  background: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0;
  width: 100%;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f5f5f5;
}

/* 作者信息 */
.author-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  border: 2rpx solid #eee;
  flex-shrink: 0;
}

.author-avatar image {
  width: 100%;
  height: 100%;
}

.author-text {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.author-label {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.btn {
  background: #f5f5f5;
  color: #666;
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  line-height: 1.5;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.btn.favorite.active {
  background: #fff5f5;
  color: #ff6b6b;
}

/* 标签区 - 左右贴边 */
.tags-section {
  background: #fff;
  padding: 30rpx;
  margin: 0;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

/* 简介 - 左右贴边 */
.desc-section {
  background: #fff;
  padding: 30rpx;
  margin: 0;
  width: 100%;
  box-sizing: border-box;
  border-top: 2rpx solid #f5f5f5;
}

.desc-text {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
}

/* 步骤区 - 左右贴边 */
.steps-section {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cook-mode-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #ff6b6b;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: normal;
}
/* 猜你喜欢 - 确保可滑动 */
.similar-section {
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
  width: 100%;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.slide-tip {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 关键：scroll-view 必须设置高度和允许横向滚动 */
.similar-scroll {
  width: 100%;
  height: 420rpx; /* 必须设置明确高度 */
  white-space: nowrap; /* 防止内部换行 */
  overflow-x: auto; /* 允许横向滚动 */
  box-sizing: border-box;
}

/* 关键：列表容器 - 使用 inline-flex 确保宽度由内容撑开 */
.similar-list {
  display: inline-flex; /* 改为 inline-flex，宽度由内容决定 */
  flex-direction: row;
  flex-wrap: nowrap; /* 强制不换行 */
  padding: 0 20rpx;
  gap: 20rpx;
  vertical-align: top; /* 对齐方式 */
  /* 不要设置 width: 100% 或 max-content，让内容自动撑开 */
}

/* 单个卡片 - 固定宽度，不压缩 */
.similar-card {
  width: 280rpx;
  height: 400rpx; /* 设置固定高度 */
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  flex-shrink: 0; /* 关键：防止被压缩 */
  display: inline-block; /* 确保横向排列 */
  vertical-align: top;
}

.similar-card:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.similar-image {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.similar-initial {
  font-size: 80rpx;
  color: rgba(255,255,255,0.95);
  font-weight: bold;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.similar-rating {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(255,255,255,0.95);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ff9500;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.similar-info {
  padding: 20rpx;
  background: #fff;
  height: 120rpx; /* 固定高度 */
  box-sizing: border-box;
}

.similar-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.similar-meta {
  font-size: 24rpx;
  color: #999;
  display: block;
}