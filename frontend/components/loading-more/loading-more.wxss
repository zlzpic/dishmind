.loading-container {
  padding: 40rpx 0;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #999;
  font-size: 28rpx;
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #ff6b6b;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #ccc;
  font-size: 24rpx;
}

.no-more .line {
  width: 60rpx;
  height: 2rpx;
  background: #eee;
}

.empty {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty .icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty .text {
  color: #999;
  font-size: 28rpx;
}