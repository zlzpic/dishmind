/* components/recipe-card/recipe-card.wxss */
.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.recipe-card:active {
  transform: scale(0.98);
}

.image-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.placeholder-text {
  font-size: 60rpx;
  color: rgba(255,255,255,0.9);
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0; /* 防止flex子项溢出 */
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.difficulty {
  color: #ff6b6b;
  background: rgba(255,107,107,0.1);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.time, .rating {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.rating {
  color: #ffa500;
}

.author {
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8rpx;
}