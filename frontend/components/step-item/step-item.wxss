.step-item {
  position: relative;
  padding-left: 100rpx;
  margin-bottom: 40rpx;
}

.step-header {
  position: absolute;
  left: 0;
  top: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 70rpx;
  height: 70rpx;
  background: #ff6b6b;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.step-time {
  font-size: 24rpx;
  color: #ff6b6b;
  background: rgba(255,107,107,0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 占位图样式（方案一：纯色+序号） */
.step-placeholder {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 添加装饰性渐变，让纯色不那么单调 */
.step-placeholder::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
}

.placeholder-text {
  font-size: 48rpx;
  color: rgba(255,255,255,0.95);
  font-weight: bold;
  z-index: 1;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

/* 实际图片 */
.step-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: block;
}

.step-desc {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.step-tip {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}